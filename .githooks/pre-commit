#!/bin/sh
# Pre-commit hook: runs build, type-check, tests, lint, and code quality scanner
# Install: git config core.hooksPath .githooks

set -e

echo "🔍 Running pre-commit checks..."

cd tasksync-chat

echo "📦 Building..."
node esbuild.js > /dev/null 2>&1

echo "🔎 Type-checking..."
npx tsc --noEmit

echo "🧪 Running tests..."
npx vitest run

echo "🧹 Linting..."
npm run lint

echo "🔁 Running code quality checks..."
node scripts/check-code-quality.js

echo "✅ All pre-commit checks passed!"
